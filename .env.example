ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Webull credentials
WEBULL_USERNAME=your@email.com
WEBULL_PASSWORD=your-password
WEBULL_TRADING_PIN=000000
WEBULL_DEVICE_ID=your-device-id

# TradingView credentials (used by Playwright login)
TRADINGVIEW_USERNAME=your@email.com
TRADINGVIEW_PASSWORD=your-password

# Path to tradingview_mcp_jackson Node.js server
TRADINGVIEW_MCP_PATH=C:\_repo\tradingview_mcp_jackson

# Risk controls
MAX_POSITION_SIZE_USD=1000
MAX_DAILY_LOSS_USD=500

# News agent watchlist (comma-separated tickers to monitor pre-market)
# WATCHLIST=AAPL,TSLA,GME

# Watchlist screening criteria
NEWS_MAX_PRICE=20.0
NEWS_MAX_FLOAT_M=20.0
NEWS_MAX_MARKET_CAP_M=500.0

# Pre-market scan window (EST, 24h)
NEWS_SCAN_START_HOUR=7
NEWS_SCAN_END_HOUR=9
NEWS_SCAN_END_MINUTE=30
NEWS_POLL_INTERVAL_SEC=60

# Chart agent polling interval in seconds
# (also settable via --chart-poll CLI arg)

# Safety: set to true only when ready to allow real order execution
EXECUTION_ENABLED=false
